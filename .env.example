# AutoMemoryBench environment configuration.
# Copy to `.env` and fill in your own values, then `source .env` (or use a tool
# like direnv / python-dotenv). No keys are stored in the repository.

# --- Backbone LLM endpoint (OpenAI-compatible) -------------------------------
# Any provider that serves an OpenAI-compatible /chat/completions API works:
# the official API, a self-hosted vLLM/SGLang server, or an aggregator.
export OPENAI_BASE_URL="https://your-openai-compatible-endpoint/v1"
export OPENAI_API_KEY="sk-your-key-here"

# --- Embedding endpoint (for memory systems that embed) ----------------------
# Defaults to OPENAI_BASE_URL/OPENAI_API_KEY if unset. The reference embedder in
# the paper is BAAI/bge-m3.
# export EMBEDDING_BASE_URL="https://your-embedding-endpoint/v1"
# export EMBEDDING_API_KEY="sk-your-embedding-key"

# --- Optional per-model endpoint overrides -----------------------------------
# Closed frontier models may live on a different host than the open-weight ones.
# These fall back to OPENAI_BASE_URL when unset (see configs/model_registry.json).
# export GPT_BASE_URL="https://your-gpt-endpoint/v1"
# export CLAUDE_BASE_URL="https://your-claude-endpoint/v1"

# --- Managed memory-service keys (only if you evaluate those systems) ---------
# export ZEP_API_KEY="..."
# export SUPERMEMORY_API_KEY="..."
